<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FIC Deneme Cevap Anahtarı</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Playfair+Display:wght@700&family=Montserrat:wght@400;700;900&family=Courier+Prime&family=Roboto+Mono:wght@700&family=Poppins:wght@300;600;800&display=swap');

        /* Temel Ayarlar */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f0f0f;
            color: #ffffff;
            margin: 0;
            padding: 10px;
            overflow-x: hidden;
        }

        .container { max-width: 1200px; margin: 0 auto; position: relative; }

        /* Neon Logo */
        .neon-text {
            color: #ff0000;
            text-shadow: 0 0 3px #ff0000, 0 0 8px rgba(255, 0, 0, 0.4);
            font-weight: 900;
            font-style: italic;
        }

        /* Branş Sütunları */
        .answer-column {
            background: #ffffff;
            color: #333;
            border-radius: 4px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }

        .column-title {
            text-align: center;
            font-weight: bold;
            padding: 6px 2px;
            color: white;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }

        .row {
            display: flex;
            justify-content: space-between;
            padding: 2px 6px;
            font-size: 0.7rem;
            border-bottom: 1px solid #f0f0f0;
        }

        @media (min-width: 768px) { .row { font-size: 0.85rem; padding: 4px 12px; } }

        .row:nth-child(even) { background-color: #f8f8f8; }
        .q-num { color: #bbb; font-weight: 600; width: 22px; }
        .q-ans { color: #2980b9; font-weight: 800; text-align: right; }

        /* Slicer */
        .slicer {
            height: 1px;
            width: 100%;
            margin: 25px 0;
            background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.15), transparent);
            position: relative;
        }

        /* Grid Sistemi */
        .forced-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; }
        @media (min-width: 768px) { .forced-grid { gap: 15px; } }

        /* Branş Renkleri (Varsayılan) */
        .header-turkce { background-color: #f39c12; }
        .header-sosyal { background-color: #00c0ef; }
        .header-matematik { background-color: #e011d0; }
        .header-fen { background-color: #00a65a; }

        /* Sayfa Geçişleri */
        .page { transition: opacity 0.6s ease-in-out; opacity: 0; display: none; }
        .page-active { display: block; opacity: 1; }

        /* Loading */
        #loading-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #0f0f0f; z-index: 9999; justify-content: center; align-items: center;
            flex-direction: column; opacity: 0; transition: opacity 0.5s ease-in-out;
        }
        .spinner { width: 60px; height: 60px; border: 5px solid #222; border-top: 5px solid #ff0000; border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* Panel Stilleri */
        .control-panel { background: #1a1a1a; padding: 20px; border-radius: 12px; border: 1px solid #333; }
        textarea, .input-field { width: 100%; background: #252525; border: 1px solid #444; color: #00ff00; padding: 8px; border-radius: 6px; font-family: 'Courier New', monospace; font-size: 0.8rem; }
        .input-field { color: white; font-family: 'Inter', sans-serif; margin-bottom: 5px; }
        .active-mode { background: #ff0000 !important; color: white !important; }

        /* TEMA TANIMLARI (ÇIKTI) */
        .theme-sapphire #capture-area { background-color: #041421; font-family: 'Montserrat', sans-serif; }
        .theme-sapphire .answer-column { background: #0a2339; color: #e0e0e0; border: 1px solid #1a3a5a; }
        .theme-sapphire .row { border-color: #1a3a5a; }
        .theme-sapphire .row:nth-child(even) { background-color: #0c2a44; }
        .theme-sapphire .q-ans { color: #00d2ff; }
        .theme-sapphire .slicer { background: linear-gradient(to right, transparent, rgba(0, 210, 255, 0.2), transparent); }

        .theme-rosegold #capture-area { background-color: #4d1d36; font-family: 'Poppins', sans-serif; }
        .theme-rosegold .answer-column { background: #fff1f6; color: #702444; border: 1px solid #f8bbd0; }
        .theme-rosegold .row { border-color: #f8bbd0; }
        .theme-rosegold .row:nth-child(even) { background-color: #fce4ec; }
        .theme-rosegold .q-ans { color: #d81b60; }
        .theme-rosegold .slicer { background: linear-gradient(to right, transparent, rgba(216, 27, 96, 0.3), transparent); }

        .theme-midnight #capture-area { background-color: #020617; font-family: 'Inter', sans-serif; }
        .theme-midnight .answer-column { background: #1e293b; color: #f8fafc; border: 1px solid #334155; }
        .theme-midnight .row { border-color: #334155; }
        .theme-midnight .row:nth-child(even) { background-color: #0f172a; }
        .theme-midnight .q-ans { color: #38bdf8; }
        .theme-midnight .header-turkce { background-color: #312e81 !important; }
        .theme-midnight .header-sosyal { background-color: #1e40af !important; }
        .theme-midnight .header-matematik { background-color: #4c1d95 !important; }
        .theme-midnight .header-fen { background-color: #0891b2 !important; }
        .theme-midnight .slicer { background: linear-gradient(to right, transparent, rgba(56, 189, 248, 0.2), transparent); }

        .theme-platinum #capture-area { background-color: #111111; font-family: 'Montserrat', sans-serif; }
        .theme-platinum .answer-column { background: #fdfdfd; color: #1a1a1a; border: 1px solid #e5e7eb; }
        .theme-platinum .row { border-color: #f3f4f6; }
        .theme-platinum .row:nth-child(even) { background-color: #f9fafb; }
        .theme-platinum .q-ans { color: #1e293b; text-shadow: none; font-weight: 900; }
        .theme-platinum .column-title { color: #fff; font-weight: 900; text-shadow: 0 1px 2px rgba(0,0,0,0.1); }
        .theme-platinum .header-turkce { background-color: #4338ca !important; }
        .theme-platinum .header-sosyal { background-color: #0d9488 !important; }
        .theme-platinum .header-matematik { background-color: #be185d !important; }
        .theme-platinum .header-fen { background-color: #0369a1 !important; }
        .theme-platinum .slicer { background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), transparent); }

        .theme-minimal #capture-area { background-color: #ffffff; font-family: 'Inter', sans-serif; }
        .theme-minimal .answer-column { background: #fcfcfc; color: #000; border: 1px solid #eee; box-shadow: none; }
        .theme-minimal .row { border-color: #f0f0f0; }
        .theme-minimal .q-ans { color: #000; font-weight: 900; }
        .theme-minimal .neon-text { color: #000; text-shadow: none; }
        .theme-minimal h1 { color: #000 !important; }
        .theme-minimal .slicer { background: linear-gradient(to right, transparent, rgba(0, 0, 0, 0.08), transparent); }

        /* TEMA ÖNİZLEME KARTLARI - GERÇEK RENKLER */
        .theme-preview-card {
            width: 100%; max-width: 140px; height: 110px; border-radius: 12px; padding: 8px; cursor: pointer; transition: 0.4s; border: 2px solid transparent; display: flex; flex-direction: column; gap: 5px; position: relative; overflow: hidden; scale: 0.9;
        }
        .theme-preview-card.active { border-color: #ff0000; box-shadow: 0 10px 20px rgba(255, 0, 0, 0.2); scale: 1; }

        .mini-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; flex: 1; }
        .mini-col { border-radius: 1px; display: flex; flex-direction: column; overflow: hidden; }
        .mini-head { height: 4px; width: 100%; }
        .mini-row { font-size: 5px; padding: 1px; display: flex; justify-content: space-between; align-items: center; background: white; color: #333; }
        
        /* Önizleme Spesifik Renk Fixleri */
        .preview-default { background: #0f0f0f; }
        
        .preview-sapphire { background: #041421; }
        .preview-sapphire .mini-row { background: #0a2339; color: #fff; }
        
        .preview-rosegold { background: #4d1d36; }
        .preview-rosegold .mini-row { background: #fff1f6; color: #702444; }
        
        .preview-midnight { background: #020617; }
        .preview-midnight .mini-row { background: #1e293b; color: #fff; }
        /* Midnight Preview Branş Renkleri */
        .preview-midnight .header-turkce { background-color: #312e81 !important; }
        .preview-midnight .header-sosyal { background-color: #1e40af !important; }
        .preview-midnight .header-matematik { background-color: #4c1d95 !important; }
        .preview-midnight .header-fen { background-color: #0891b2 !important; }

        .preview-platinum { background: #111111; }
        .preview-platinum .mini-row { background: #fdfdfd; color: #1a1a1a; }
        /* Platinum Preview Branş Renkleri */
        .preview-platinum .header-turkce { background-color: #4338ca !important; }
        .preview-platinum .header-sosyal { background-color: #0d9488 !important; }
        .preview-platinum .header-matematik { background-color: #be185d !important; }
        .preview-platinum .header-fen { background-color: #0369a1 !important; }

        .preview-minimal { background: #f5f5f5; }
        .preview-minimal .mini-row { background: #fff; color: #000; }

        /* OLUŞTUR BUTONU */
        .generate-btn {
            background: #ff0000; color: white; padding: 14px 40px; border-radius: 8px; font-weight: 900; text-transform: uppercase; letter-spacing: 3px; transition: all 0.3s; cursor: pointer; border: 2px solid #ff0000; box-shadow: 0 0 20px rgba(255, 0, 0, 0.4);
        }
        .generate-btn:hover { background: #cc0000; box-shadow: 0 0 30px rgba(255, 0, 0, 0.6); transform: scale(1.05); }

        /* İNDİRME AÇILIR MENÜSÜ */
        .dropdown { position: relative; display: inline-block; }
        .dropdown-content {
            display: none; position: absolute; right: 0; background-color: #1a1a1a; min-width: 160px; box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5); z-index: 50; border-radius: 8px; border: 1px solid #333; overflow: hidden; margin-top: 5px;
        }
        .dropdown-content button {
            color: #ccc; padding: 12px 16px; text-decoration: none; display: block; width: 100%; text-align: left; font-size: 12px; font-weight: bold; transition: 0.2s;
        }
        .dropdown-content button:hover { background-color: #333; color: #fff; }
        .show { display: block; }

        /* Masaüstü Yakalama Modu */
        .capture-mode-active { width: 1100px !important; min-width: 1100px !important; padding: 40px !important; border-radius: 0 !important; }
        .capture-mode-active .forced-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 20px !important; }
        .capture-mode-active .answer-column { box-shadow: none !important; border: 1px solid #eee !important; }
        .theme-sapphire .capture-mode-active .answer-column { border-color: #1a3a5a !important; }
        .theme-midnight .capture-mode-active .answer-column { border-color: #334155 !important; }
        .theme-rosegold .capture-mode-active .answer-column { border-color: #f8bbd0 !important; }
    </style>
</head>
<body>

    <div id="loading-overlay">
        <div class="spinner"></div>
        <p class="text-red-600 font-bold tracking-[0.4em] text-xs animate-pulse">İşleniyor...</p>
    </div>

    <div class="container py-4">
        <!-- AYARLAR SAYFASI -->
        <div id="page-input" class="page page-active" style="opacity: 1;">
            <div class="control-panel">
                <div class="flex flex-wrap justify-between items-center mb-6 gap-2">
                    <h2 class="text-xl font-bold text-gray-400 tracking-widest uppercase">⚙️ Yapılandırma</h2>
                    <div class="flex gap-2">
                        <button onclick="toggleBranchSettings()" class="text-[10px] bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-1 rounded border border-gray-700 transition">🔧 Branşlar</button>
                        <button onclick="toggleThemeSettings()" class="text-[10px] bg-red-900/30 hover:bg-red-900/50 text-red-300 px-3 py-1 rounded border border-red-800 transition">🎨 Temalar</button>
                    </div>
                </div>

                <div id="branch-settings" class="hidden mb-6 p-4 bg-black/20 rounded-lg border border-white/5">
                    <p class="text-[10px] font-bold text-gray-500 mb-3 uppercase">Branş İsimlerini Ayarla</p>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        <input type="text" id="name-1" value="TÜRKÇE" class="input-field text-xs" oninput="syncLabels()">
                        <input type="text" id="name-2" value="SOSYAL" class="input-field text-xs" oninput="syncLabels()">
                        <input type="text" id="name-3" value="MATEMATİK" class="input-field text-xs" oninput="syncLabels()">
                        <input type="text" id="name-4" value="FEN" class="input-field text-xs" oninput="syncLabels()">
                    </div>
                </div>

                <div id="theme-settings" class="hidden mb-6 p-4 bg-black/20 rounded-lg border border-white/5">
                    <p class="text-[10px] font-bold text-gray-500 mb-4 uppercase text-center">Bir Tema Seç</p>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
                        <div onclick="setTheme('default')" id="t-default" class="theme-preview-card active preview-default">
                            <span class="text-[8px] text-gray-400 text-center font-bold uppercase">Standart</span>
                            <div class="mini-grid">
                                <div class="mini-col"><div class="mini-head header-turkce"></div><div class="mini-row"><span>1</span><span>A</span></div></div>
                                <div class="mini-col"><div class="mini-head header-sosyal"></div><div class="mini-row"><span>1</span><span>B</span></div></div>
                                <div class="mini-col"><div class="mini-head header-matematik"></div><div class="mini-row"><span>1</span><span>C</span></div></div>
                                <div class="mini-col"><div class="mini-head header-fen"></div><div class="mini-row"><span>1</span><span>D</span></div></div>
                            </div>
                        </div>
                        <div onclick="setTheme('sapphire')" id="t-sapphire" class="theme-preview-card preview-sapphire">
                            <span class="text-[8px] text-blue-400 text-center font-bold uppercase">Safir</span>
                            <div class="mini-grid">
                                <div class="mini-col"><div class="mini-head header-turkce"></div><div class="mini-row"><span>1</span><span>A</span></div></div>
                                <div class="mini-col"><div class="mini-head header-sosyal"></div><div class="mini-row"><span>1</span><span>B</span></div></div>
                                <div class="mini-col"><div class="mini-head header-matematik"></div><div class="mini-row"><span>1</span><span>C</span></div></div>
                                <div class="mini-col"><div class="mini-head header-fen"></div><div class="mini-row"><span>1</span><span>D</span></div></div>
                            </div>
                        </div>
                        <div onclick="setTheme('rosegold')" id="t-rosegold" class="theme-preview-card preview-rosegold">
                            <span class="text-[8px] text-pink-300 text-center font-bold uppercase">Gül Altın</span>
                            <div class="mini-grid">
                                <div class="mini-col"><div class="mini-head header-turkce"></div><div class="mini-row"><span>1</span><span>A</span></div></div>
                                <div class="mini-col"><div class="mini-head header-sosyal"></div><div class="mini-row"><span>1</span><span>B</span></div></div>
                                <div class="mini-col"><div class="mini-head header-matematik"></div><div class="mini-row"><span>1</span><span>C</span></div></div>
                                <div class="mini-col"><div class="mini-head header-fen"></div><div class="mini-row"><span>1</span><span>D</span></div></div>
                            </div>
                        </div>
                        <div onclick="setTheme('midnight')" id="t-midnight" class="theme-preview-card preview-midnight">
                            <span class="text-[8px] text-cyan-400 text-center font-bold uppercase">Gece Mavisi</span>
                            <div class="mini-grid">
                                <div class="mini-col"><div class="mini-head header-turkce"></div><div class="mini-row"><span>1</span><span>A</span></div></div>
                                <div class="mini-col"><div class="mini-head header-sosyal"></div><div class="mini-row"><span>1</span><span>B</span></div></div>
                                <div class="mini-col"><div class="mini-head header-matematik"></div><div class="mini-row"><span>1</span><span>C</span></div></div>
                                <div class="mini-col"><div class="mini-head header-fen"></div><div class="mini-row"><span>1</span><span>D</span></div></div>
                            </div>
                        </div>
                        <div onclick="setTheme('platinum')" id="t-platinum" class="theme-preview-card preview-platinum">
                            <span class="text-[8px] text-gray-200 text-center font-bold uppercase">Platin</span>
                            <div class="mini-grid">
                                <div class="mini-col"><div class="mini-head header-turkce"></div><div class="mini-row"><span>1</span><span>A</span></div></div>
                                <div class="mini-col"><div class="mini-head header-sosyal"></div><div class="mini-row"><span>1</span><span>B</span></div></div>
                                <div class="mini-col"><div class="mini-head header-matematik"></div><div class="mini-row"><span>1</span><span>C</span></div></div>
                                <div class="mini-col"><div class="mini-head header-fen"></div><div class="mini-row"><span>1</span><span>D</span></div></div>
                            </div>
                        </div>
                        <div onclick="setTheme('minimal')" id="t-minimal" class="theme-preview-card preview-minimal">
                            <span class="text-[8px] text-gray-800 text-center font-bold uppercase">Minimal</span>
                            <div class="mini-grid">
                                <div class="mini-col"><div class="mini-head header-turkce"></div><div class="mini-row"><span>1</span><span>A</span></div></div>
                                <div class="mini-col"><div class="mini-head header-sosyal"></div><div class="mini-row"><span>1</span><span>B</span></div></div>
                                <div class="mini-col"><div class="mini-head header-matematik"></div><div class="mini-row"><span>1</span><span>C</span></div></div>
                                <div class="mini-col"><div class="mini-head header-fen"></div><div class="mini-row"><span>1</span><span>D</span></div></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Deneme Başlığı</label>
                        <input type="text" id="input-title" value="TOPRAK TG202606" class="w-full bg-gray-800 border border-gray-700 p-3 rounded text-white text-sm focus:outline-none focus:border-red-600">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Sınav Türü</label>
                        <div class="flex gap-2">
                            <button id="mode-tyt" onclick="setMode('TYT')" class="flex-1 bg-gray-800 p-3 rounded font-bold text-sm transition">TYT</button>
                            <button id="mode-ayt" onclick="setMode('AYT')" class="flex-1 bg-gray-800 p-3 rounded font-bold text-sm active-mode transition">AYT</button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Kitapçık</label>
                        <div class="flex gap-1">
                            <button onclick="setBooklet('A')" class="booklet-btn flex-1 bg-gray-800 p-3 rounded font-bold text-sm active-mode" id="btn-A">A</button>
                            <button onclick="setBooklet('B')" class="booklet-btn flex-1 bg-gray-800 p-3 rounded font-bold text-sm" id="btn-B">B</button>
                            <button onclick="setBooklet('C')" class="booklet-btn flex-1 bg-gray-800 p-3 rounded font-bold text-sm" id="btn-C">C</button>
                            <button onclick="setBooklet('D')" class="booklet-btn flex-1 bg-gray-800 p-3 rounded font-bold text-sm" id="btn-D">D</button>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
                    <div><label id="label-1" class="block text-[10px] font-bold text-orange-500 mb-1 uppercase">TÜRKÇE</label><textarea id="ans-1" rows="4" placeholder="ABC..."></textarea></div>
                    <div><label id="label-2" class="block text-[10px] font-bold text-cyan-500 mb-1 uppercase">SOSYAL</label><textarea id="ans-2" rows="4" placeholder="ABC..."></textarea></div>
                    <div><label id="label-3" class="block text-[10px] font-bold text-purple-500 mb-1 uppercase">MATEMATİK</label><textarea id="ans-3" rows="4" placeholder="ABC..."></textarea></div>
                    <div><label id="label-4" class="block text-[10px] font-bold text-green-500 mb-1 uppercase">FEN</label><textarea id="ans-4" rows="4" placeholder="ABC..."></textarea></div>
                </div>

                <div class="text-center">
                    <button class="generate-btn w-full md:w-auto" onclick="startTransition()">Anahtarı Oluştur</button>
                </div>
            </div>
        </div>

        <div id="page-output" class="page">
            <div class="flex flex-wrap justify-between items-center mb-6 gap-2 no-capture">
                <button onclick="reverseTransition()" class="text-xs bg-gray-900 hover:bg-gray-800 text-white px-5 py-2 rounded-full border border-gray-700 flex items-center gap-2 transition active:scale-95 shadow-xl">
                    <span>←</span> Ayarları Düzenle
                </button>
                <div class="dropdown">
                    <button id="download-btn" onclick="toggleDropdown()" class="text-xs bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-full border border-red-500 flex items-center gap-2 transition active:scale-95 font-bold shadow-xl">
                        <span>📥</span> Anahtarı İndir ▼
                    </button>
                    <div id="download-menu" class="dropdown-content">
                        <button onclick="processDownload('png')">🖼️ PNG Olarak Kaydet</button>
                        <button onclick="processDownload('jpg')">📷 JPG Olarak Kaydet (Hızlı)</button>
                        <button onclick="processDownload('pdf')">📄 PDF Belgesi Yap</button>
                    </div>
                </div>
            </div>

            <div id="capture-container">
                <div id="capture-area" class="p-6 rounded-2xl transition-all duration-300">
                    <header class="flex justify-between items-end pb-2">
                        <div class="flex-1">
                            <h1 id="display-title" class="text-lg md:text-3xl font-black text-orange-500 tracking-tighter uppercase leading-none"></h1>
                            <p id="display-booklet" class="text-[10px] md:text-base font-bold text-orange-600 mt-2"></p>
                        </div>
                        <div class="text-right">
                            <span class="neon-text text-2xl md:text-4xl">FIC Deneme</span>
                        </div>
                    </header>
                    <div class="slicer"></div>
                    <div class="forced-grid" id="grid-container"></div>
                    <footer class="mt-10 text-center text-[10px] text-gray-500/50 tracking-widest uppercase pt-6 border-t border-gray-800/20">
                        FIC Deneme - CevapAnahtarı
                    </footer>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentMode = 'AYT';
        let currentBooklet = 'A';
        let currentTheme = 'default';

        function toggleDropdown() { document.getElementById("download-menu").classList.toggle("show"); }
        window.onclick = function(event) {
            if (!event.target.matches('#download-btn')) {
                const dropdowns = document.getElementsByClassName("dropdown-content");
                for (let i = 0; i < dropdowns.length; i++) {
                    if (dropdowns[i].classList.contains('show')) dropdowns[i].classList.remove('show');
                }
            }
        }

        function setTheme(theme) {
            currentTheme = theme;
            document.querySelectorAll('.theme-preview-card').forEach(card => card.classList.remove('active'));
            document.getElementById('t-' + theme).classList.add('active');
        }

        function toggleBranchSettings() { document.getElementById('branch-settings').classList.toggle('hidden'); }
        function toggleThemeSettings() { document.getElementById('theme-settings').classList.toggle('hidden'); }

        function syncLabels() {
            for(let i=1; i<=4; i++) {
                document.getElementById('label-'+i).innerText = document.getElementById('name-'+i).value || '-';
            }
        }

        function setMode(mode) {
            currentMode = mode;
            document.getElementById('mode-tyt').classList.toggle('active-mode', mode === 'TYT');
            document.getElementById('mode-ayt').classList.toggle('active-mode', mode === 'AYT');
        }

        function setBooklet(type) {
            currentBooklet = type;
            document.querySelectorAll('.booklet-btn').forEach(btn => btn.classList.remove('active-mode'));
            document.getElementById('btn-' + type).classList.add('active-mode');
        }

        function startTransition() {
            const pageInput = document.getElementById('page-input');
            const loader = document.getElementById('loading-overlay');
            const pageOutput = document.getElementById('page-output');
            pageInput.style.opacity = '0';
            setTimeout(() => {
                pageInput.classList.remove('page-active');
                loader.style.display = 'flex';
                setTimeout(() => loader.style.opacity = '1', 50);
                setTimeout(() => {
                    renderAnswers();
                    loader.style.opacity = '0';
                    setTimeout(() => {
                        loader.style.display = 'none';
                        pageOutput.classList.add('page-active');
                        pageOutput.className = 'page page-active theme-' + currentTheme;
                        setTimeout(() => { pageOutput.style.opacity = '1'; }, 50);
                        window.scrollTo(0,0);
                    }, 500);
                }, 1200);
            }, 500);
        }

        function reverseTransition() {
            const pageInput = document.getElementById('page-input');
            const pageOutput = document.getElementById('page-output');
            pageOutput.style.opacity = '0';
            setTimeout(() => {
                pageOutput.classList.remove('page-active');
                pageInput.classList.add('page-active');
                setTimeout(() => pageInput.style.opacity = '1', 50);
                window.scrollTo(0,0);
            }, 500);
        }

        function renderAnswers() {
            const titleInput = document.getElementById('input-title').value;
            const gridContainer = document.getElementById('grid-container');
            document.getElementById('display-title').innerText = `${titleInput} ${currentMode}`;
            document.getElementById('display-booklet').innerText = `${currentBooklet} KİTAPÇIĞI`;
            gridContainer.innerHTML = '';
            const names = [1,2,3,4].map(i => document.getElementById('name-'+i).value);
            const colors = ['header-turkce', 'header-sosyal', 'header-matematik', 'header-fen'];
            const counts = currentMode === 'TYT' ? [40, 20, 40, 20] : [40, 40, 40, 40];

            for (let b = 0; b < 4; b++) {
                const col = document.createElement('div');
                col.className = 'answer-column';
                const header = document.createElement('div');
                header.className = `column-title ${colors[b]}`;
                header.innerText = names[b];
                col.appendChild(header);
                const list = document.createElement('div');
                list.className = 'flex flex-col';
                const raw = document.getElementById('ans-' + (b+1)).value.toUpperCase().replace(/\s/g, '');
                for (let i = 1; i <= counts[b]; i++) {
                    const row = document.createElement('div');
                    row.className = 'row';
                    let char = raw[i - 1] || "-";
                    if (char === 'X' || char === '') char = "-";
                    row.innerHTML = `<span class="q-num">${i}.</span><span class="q-ans">${char}</span>`;
                    list.appendChild(row);
                }
                col.appendChild(list);
                gridContainer.appendChild(col);
            }
        }

        async function processDownload(format) {
            const area = document.getElementById('capture-area');
            const title = document.getElementById('input-title').value || 'FIC_Anahtar';
            const loader = document.getElementById('loading-overlay');
            loader.style.display = 'flex';
            loader.style.opacity = '1';
            area.classList.add('capture-mode-active');

            let bgColor = '#0f0f0f';
            if (currentTheme === 'minimal') bgColor = '#ffffff';
            else if (currentTheme === 'platinum') bgColor = '#111111';
            else if (currentTheme === 'rosegold') bgColor = '#4d1d36';
            else if (currentTheme === 'midnight') bgColor = '#020617';
            else if (currentTheme === 'sapphire') bgColor = '#041421';

            await new Promise(r => setTimeout(r, 100));
            try {
                const canvas = await html2canvas(area, {
                    backgroundColor: bgColor,
                    scale: 3,
                    useCORS: true,
                    allowTaint: true,
                    logging: false
                });
                if (format === 'pdf') {
                    const { jsPDF } = window.jspdf;
                    const pdf = new jsPDF('l', 'mm', 'a4');
                    const imgData = canvas.toDataURL('image/jpeg', 1.0);
                    const imgProps = pdf.getImageProperties(imgData);
                    const pdfWidth = pdf.internal.pageSize.getWidth();
                    const pdfHeight = (imgProps.height * pdfWidth) / imgProps.width;
                    pdf.addImage(imgData, 'JPEG', 0, 0, pdfWidth, pdfHeight);
                    pdf.save(`${title}_${currentMode}.pdf`);
                } else {
                    const link = document.createElement('a');
                    link.download = `${title}_${currentMode}.${format}`;
                    link.href = canvas.toDataURL(`image/${format === 'png' ? 'png' : 'jpeg'}`, 1.0);
                    link.click();
                }
            } catch (err) { console.error(err); } finally {
                area.classList.remove('capture-mode-active');
                loader.style.opacity = '0';
                setTimeout(() => loader.style.display = 'none', 500);
            }
        }
    </script>
</body>
</html>
